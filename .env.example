# بوابة الهدى الرقمية - ملف البيئة التجريبي
# Al-Huda Gateway - Environment Variables Example

# ====================================
# معلومات التطبيق / Application Info
# ====================================
APP_NAME="بوابة الهدى الرقمية"
APP_VERSION="1.0.5"
APP_ENV="production"

# ====================================
# معلومات الاتصال / Contact Information
# ====================================
CONTACT_PHONE="0123456789"
CONTACT_EMAIL="info@alhuda.com"
CONTACT_ADDRESS="برج الهدى، القاهرة، مصر"

# ====================================
# إعدادات النظام / System Settings
# ====================================
# فترة التحديث التلقائي بالميلي ثانية (30000 = 30 ثانية)
AUTO_REFRESH_INTERVAL=30000

# الحد الأقصى لحجم localStorage (بالميجابايت)
MAX_STORAGE_SIZE=10

# ====================================
# إعدادات الأمان / Security Settings
# ====================================
# مدة الجلسة بالدقائق
SESSION_TIMEOUT=60

# عدد محاولات تسجيل الدخول الفاشلة المسموح بها
MAX_LOGIN_ATTEMPTS=5

# مدة الحظر بعد تجاوز المحاولات (بالدقائق)
LOCKOUT_DURATION=15

# ====================================
# إعدادات المدفوعات / Payment Settings
# ====================================
# الرسوم الشهرية الافتراضية (بالجنيه المصري)
DEFAULT_MONTHLY_FEE=200

# طرق الدفع المتاحة (مفصولة بفاصلة)
PAYMENT_METHODS="نقداً,InstaPay,فودافون كاش,تحويل بنكي"

# ====================================
# إعدادات الإشعارات / Notification Settings
# ====================================
# تفعيل الإشعارات
ENABLE_NOTIFICATIONS=true

# تفعيل إشعارات البريد الإلكتروني
ENABLE_EMAIL_NOTIFICATIONS=false

# تفعيل إشعارات SMS
ENABLE_SMS_NOTIFICATIONS=false

# ====================================
# إعدادات النسخ الاحتياطي / Backup Settings
# ====================================
# تفعيل النسخ الاحتياطي التلقائي
AUTO_BACKUP_ENABLED=true

# فترة النسخ الاحتياطي (بالساعات)
BACKUP_INTERVAL=24

# عدد النسخ الاحتياطية المحفوظة
BACKUP_RETENTION=7

# ====================================
# إعدادات التطوير / Development Settings
# ====================================
# تفعيل وضع التطوير (true/false)
DEBUG_MODE=false

# عرض رسائل console.log
SHOW_CONSOLE_LOGS=false

# ====================================
# ملاحظات / Notes
# ====================================
# 1. انسخ هذا الملف إلى .env وعدل القيم حسب احتياجاتك
# 2. لا تشارك ملف .env مع أحد - يحتوي على معلومات حساسة
# 3. أضف .env إلى .gitignore لمنع رفعه إلى Git
# 4. في الإنتاج، استخدم APP_ENV="production"
# 5. في التطوير، استخدم APP_ENV="development"
